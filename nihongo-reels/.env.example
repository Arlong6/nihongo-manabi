# ── instagrapi (legacy, being phased out) ────────────────────────────────────
IG_USERNAME=learn.nihongo.manabi
IG_SESSION_ID=

# ── Meta Graph API (new, official) ───────────────────────────────────────────
# Get these from developers.facebook.com after creating a Business app + linking
# Facebook Page + Instagram Business account.
#
# Quick reference:
#   IG_GRAPH_APP_ID       → Meta app settings → Basic → App ID
#   IG_GRAPH_APP_SECRET   → Meta app settings → Basic → App Secret
#   IG_GRAPH_USER_ID      → Graph API Explorer: GET /me/accounts → instagram_business_account.id
#   IG_GRAPH_TOKEN        → long-lived token (60d); exchange from short-lived via /oauth/access_token
#   IG_GRAPH_TOKEN_EXPIRES → ISO timestamp, auto-updated by ig_token_refresh.py
IG_GRAPH_APP_ID=
IG_GRAPH_APP_SECRET=
IG_GRAPH_USER_ID=
IG_GRAPH_TOKEN=
IG_GRAPH_TOKEN_EXPIRES=

# Video hosting for Graph API (reels must be fetched from a public URL)
IG_VIDEO_REPO=Arlong6/nihongo-manabi
IG_VIDEO_RELEASE_TAG=reels-assets

# ── Telegram notifications (optional, falls back to AIvideo/.env) ────────────
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=
